# Dockerfile for Marketeer Edge Router

FROM rust:1.75 as builder

WORKDIR /app

# Copy Cargo files
COPY Cargo.toml ./
COPY . .

# Build release binary
RUN cargo build --release --bin marketeer

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy binary from builder
COPY --from=builder /app/target/release/marketeer /app/marketeer

# Copy config
COPY config/marketeer.toml /app/config/marketeer.toml

EXPOSE 8000

CMD ["/app/marketeer"]
