# Dockerfile for Co-Driver API Gateway

FROM rust:1.75 as builder

WORKDIR /app

# Copy everything
COPY Cargo.toml ./
COPY ../package/rust-crate/rag::qdrant ../package/rust-crate/rag::qdrant
COPY ../package/rust-crate/mcp ../package/rust-crate/mcp
COPY . .

# Build release binary
RUN cargo build --release --bin codriver

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy binary from builder
COPY --from=builder /app/target/release/codriver /app/codriver

# Copy config
COPY config/codriver.toml /app/config/codriver.toml

EXPOSE 8001

CMD ["/app/codriver"]
