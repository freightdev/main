# Marketeer Configuration
MARKETEER_LISTEN_ADDR=0.0.0.0
MARKETEER_LISTEN_PORT=8000
MARKETEER_API_KEY=change-me-in-production
CODRIVER_URL=http://localhost:8001

# Co-Driver Configuration
CODRIVER_LISTEN_ADDR=0.0.0.0
CODRIVER_LISTEN_PORT=8001

# LLM Backends
OLLAMA_URL=http://localhost:11434
LLAMA_CPP_URL=http://localhost:8080

# Ollama Models to Use
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODELS=qwen2.5:7b-instruct-q4_K_M

# llama.cpp Configuration
LLAMA_CPP_MODEL_PATH=/model/model.gguf
LLAMA_CPP_N_GPU_LAYERS=35

# RAG System
QDRANT_URL=http://localhost:6333
EMBEDDING_PROVIDER=ollama
EMBEDDING_API_KEY=your_api_key_here

# MCP Configuration
MCP_SERVER_NAME=codriver
MCP_AUTH_TOKEN=your_token_here

# Database URLs (Optional)
POSTGRES_URL=postgresql://user:pass@localhost/
REDIS_URL=redis://localhost:6379
DRAGONFLY_URL=redis://localhost:6379

# Logging
RUST_LOG=info
LOG_FORMAT=json
