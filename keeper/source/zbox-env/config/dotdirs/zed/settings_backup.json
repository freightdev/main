{
  // ============================================
  // FILESYSTEM PROTECTION (Your Main Concern)
  // ============================================
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/target",
    "**/.venv",
    "**/venv",
    "**/dist",
    "**/build",
    "**/.cache",
    "~/.ssh",
    "~/.gnupg",
    "/sys",
    "/proc",
    "/dev",
    "/tmp",
    "~/.cache",
    "~/.local/share",
    "/usr",
    "/var"
  ],
  "indexed_file_path_limit": 10000,
  "project_file_scan_depth": 3,

  "file_watcher": {
    "enabled": true,
    "debounce": 100
  },

  // ============================================
  // OLLAMA MULTI-NODE SETUP
  // ============================================
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434", // Default node
      "low_speed_timeout_in_seconds": 120
    }
  },

  "assistant": {
    "enabled": true,
    "default_model": {
      "provider": "ollama",
      "model": "mistralite"
    },
    "version": "2",
    "button": true,
    "dock": "right",
    "default_width": 640
  },

  // ============================================
  // PERFORMANCE OPTIMIZATIONS
  // ============================================
  "inlay_hints": {
    "enabled": false
  },

  "lsp": {
    // Add your language servers here as needed
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": {
          "command": "clippy"
        }
      }
    }
  },

  // ============================================
  // CODE HYGIENE
  // ============================================
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "hard_tabs": false,
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",

  // ============================================
  // YOUR EXISTING SETTINGS
  // ============================================
  "show_edit_predictions": false,
  "use_system_prompts": true,
  "use_system_path_prompts": true,
  "auto_update": false,
  "disable_ai": false,

  "calls": {
    "mute_on_join": true
  },

  "git": {
    "blame": {
      "show_avatar": true
    },
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },

  "outline_panel": {
    "file_icons": true
  },

  "tabs": {
    "close_position": "right",
    "file_icons": false,
    "git_status": false
  },

  "title_bar": {
    "show_menus": true,
    "show_branch_name": true,
    "show_branch_icon": true
  },

  "terminal": {
    "scrollbar": {
      "show": "never"
    },
    "toolbar": {
      "breadcrumbs": true
    },
    "shell": "system",
    "dock": "bottom",
    "button": true
  },

  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true
  },

  "project_panel": {
    "open_file_on_paste": true,
    "hide_hidden": false,
    "hide_root": false,
    "sticky_scroll": true,
    "scrollbar": {
      "show": "never"
    },
    "auto_fold_dirs": true,
    "starts_open": true,
    "auto_reveal_entries": true,
    "git_status": true,
    "folder_icons": false,
    "file_icons": false,
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
    "default_width": 240.0,
    "dock": "left",
    "button": true
  },

  "search": {
    "regex": true
  },

  "diagnostics_max_severity": "error",

  "prettier": {
    "allowed": true
  },

  "edit_predictions": {
    "disabled_globs": []
  },

  "minimap": {
    "show": "auto"
  },

  "drag_and_drop_selection": {},
  "base_keymap": "VSCode",
  "ui_font_family": ".ZedSans",
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "buffer_font_family": ".ZedMono",
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "theme": "One Dark",

  "telemetry": {
    "metrics": false,
    "diagnostics": false
  }
}
